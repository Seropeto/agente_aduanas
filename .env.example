# Clave API de Anthropic (obligatoria)
ANTHROPIC_API_KEY=sk-ant-...

# JWT - clave secreta para firmar tokens (obligatoria en producción)
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Usuario administrador (se crea automáticamente al iniciar)
ADMIN_EMAIL=contacto@toxirodigital.cloud
ADMIN_PASSWORD=tu-password-admin

# SMTP para envío de correos
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contacto@toxirodigital.cloud
SMTP_PASSWORD=tu-password-smtp

# Tesseract OCR (opcional)
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
